# Required: Anthropic API key for the Claude Agent SDK.
ANTHROPIC_API_KEY=

# Optional path overrides. Defaults assume datasets and tokenizers are
# prepared under ./data/<task>/ as documented in the task READMEs.
# MAGENT_PG_VENV=
# MAGENT_PG_DATA_DIR=
# MAGENT_PG_TOKENIZER_DIR=
# MAGENT_NC_BASE_DIR=
# MAGENT_NC_VENV=
# MAGENT_CIFAR_DATA_DIR=

# Optional: override the supervisor state root. Defaults to ./magent_state_<task>/.
# MAGENT_LOCAL_ROOT=
